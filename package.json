{
  "name": "react-ts-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/run-react-snap.mjs && npm run seo:inject",
    "seo:inject": "node scripts/inject-seo.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.2",
    "@vapi-ai/web": "^2.3.8",
    "framer-motion": "^12.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.56.1",
    "react-icons": "^5.5.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.10.1",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@stagewise/toolbar-react": "^0.1.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.15",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.4.31",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.3.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1"
  },
  "reactSnap": {
    "source": "dist",
    "waitFor": 1500,
    "include": [
      "/",
      "/features",
      "/pricing",
      "/integrations",
      "/integrations/stripe",
      "/integrations/mpgs",
      "/integrations/chapa",
      "/integrations/telebirr",
      "/integrations/apple-pay",
      "/integrations/delivery-apps",
      "/blog",
      "/table-management",
      "/reservations"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  }
}
